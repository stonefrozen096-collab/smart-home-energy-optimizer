# Copy to .env for local dev against a hosted broker, or set these
# as GitHub repository secrets (Settings -> Secrets and variables -> Actions).
VITE_BROKER_URL=wss://your-cluster-id.s1.eu.hivemq.cloud:8884/mqtt
VITE_BROKER_USERNAME=your-hivemq-username
VITE_BROKER_PASSWORD=your-hivemq-password

# Optional: email alerts via EmailJS (https://www.emailjs.com/), free tier.
# Leave unset and email alerts are simply disabled - everything else still works.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
